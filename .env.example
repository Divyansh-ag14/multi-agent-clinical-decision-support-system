# Required
OPENAI_API_KEY=your-openai-api-key-here

# LLM settings
# LLM_MODEL=gpt-4o
# LLM_TEMPERATURE=0.3
# LLM_TIMEOUT=120
# LLM_MAX_RETRIES=2

# API settings
# API_PORT=8000
# FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000
# REQUEST_ID_HEADER=X-Request-ID

# Workflow defaults
# DEFAULT_MAX_ITERATIONS=3
# DEFAULT_CRITIC_THRESHOLD=0.7

# RAG settings
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDINGS_LOCAL_ONLY=true
# RETRIEVER_K=5
# HYBRID_RETRIEVER_K=12
# HYBRID_RRF_K=60
# LEXICAL_WEIGHT=1.0
# DENSE_WEIGHT=1.0
# RERANK_TOP_N=8
# RERANKER_MODEL=
# RERANKER_LOCAL_ONLY=true
# MAX_EVIDENCE_DOCS=20
# ENABLE_JSON_KNOWLEDGE=true
# AUTO_REBUILD_STALE_INDEX=false

# RAG chunking
# RAG_CHUNK_SIZE=1000
# RAG_CHUNK_OVERLAP=150
# MAX_CITATIONS_PER_HYPOTHESIS=3

# Logging
# LOG_LEVEL=DEBUG
# LOG_DIR=logs
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5

# Data and model paths
# DATA_DIR=data
# DB_PATH=data/patient_memory.db
# SOURCE_DOCS_DIR=data/source_docs
# PDF_SOURCES_DIR=data/source_docs/pdfs
# TEXT_SOURCES_DIR=data/source_docs/text
# MODEL_CACHE_DIR=data/model_cache
